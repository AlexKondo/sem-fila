# =============================================================
# QuickPick — Variáveis de Ambiente
# Copie este arquivo para .env.local (desenvolvimento) ou
# configure no painel do Vercel em: Settings > Environment Variables
# =============================================================

# ── Supabase ──────────────────────────────────────────────────
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...sua-anon-key

# ── URL do app ────────────────────────────────────────────────
# Desenvolvimento: http://localhost:3000
# Produção Vercel: https://seu-app.vercel.app  (ou domínio próprio)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe (opcional — planos pagos) ─────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Brevo (email transacional — opcional) ────────────────────
# https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=noreply@seudominio.com
BREVO_SENDER_NAME=QuickPick
